# Copy this file to .env and fill in your values for local development.
# On HuggingFace Spaces, set these as Repository Secrets instead.

# Required: NVIDIA NIM API key (get one at build.nvidia.com)
NVIDIA_API_KEY=nvapi-your-key-here

# Optional: Flask session secret. Randomise this in production.
SECRET_KEY=ironwood-dungeon-secret-key-2025

# Optional: Port override (HuggingFace Spaces expects 7860)
# PORT=7860
